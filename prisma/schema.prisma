  recruiterId     String         @db.Uuid // User ID of the recruiter
  talentProfileId String         @db.Uuid
  jobTitle        String
  companyName     String
  jobLocation     String         @default("")
  salaryRange     String         @default("")
  message         String         @default("")
  status          String         @default("pending") // pending, accepted, declined
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  recruiter       User           @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  talentProfile   TalentProfile  @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("talent_contact_requests")
}

model TalentShortlist {
  id              String         @id @default(uuid()) @db.Uuid
  recruiterId     String         @db.Uuid // User ID of the recruiter
  talentProfileId String         @db.Uuid
  notes           String         @default("")
  folder          String         @default("General")
  createdAt       DateTime       @default(now())

  recruiter       User           @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  talentProfile   TalentProfile  @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@unique([recruiterId, talentProfileId])
  @@map("talent_shortlists")
}

model TalentRecommendation {
  id              String         @id @default(uuid()) @db.Uuid
  talentProfileId String         @db.Uuid
  authorName      String
  authorTitle     String         @default("")
  relationship    String         @default("") // e.g., "Worked with X in same team"
  content         String
  isApproved      Boolean        @default(false)
  createdAt       DateTime       @default(now())

  talentProfile   TalentProfile  @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("talent_recommendations")
}

model TalentProfileView {
  id              String         @id @default(uuid()) @db.Uuid
  talentProfileId String         @db.Uuid
  viewerId        String?        @db.Uuid // User ID of viewer if logged in
  viewerName      String         @default("Anonymous Recruiter")
  viewerCompany   String         @default("")
  viewedAt        DateTime       @default(now())

  talentProfile   TalentProfile  @relation(fields: [talentProfileId], references: [id], onDelete: Cascade)

  @@map("talent_profile_views")
}

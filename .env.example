# ---------------------------------------------------------------------------
# Career Studio Next — environment variables
# Copy to `.env` and fill in. Anything left blank degrades gracefully:
#   - no Google AI key  → AI-unavailable banners surface, deterministic
#                         fallbacks run where possible
#   - no Stripe keys    → billing routes return 503
#   - no Resend key     → magic-link email sign-in disabled
# ---------------------------------------------------------------------------

# --- Database (required) ---------------------------------------------------
# DIRECT_URL is used by `prisma migrate`; DATABASE_URL by the runtime pool.
# In Vercel + Supabase / Neon, point DIRECT_URL at the unpooled connection.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/career_studio_next"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/career_studio_next"

# --- Auth (required) -------------------------------------------------------
# Generate AUTH_SECRET with: `openssl rand -base64 32`
AUTH_SECRET="replace-with-openssl-rand-base64"
AUTH_URL="http://localhost:3000"
# Google OAuth — leave blank to disable Google sign-in.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Resend — leave blank to disable magic-link sign-in.
AUTH_RESEND_KEY=""
RESEND_FROM_EMAIL="Career Studio <hello@careerstudio.lk>"

# --- AI (optional but recommended) -----------------------------------------
# Google Gemini key used by ATS scorer, Career GPS, LinkedIn audit, etc.
# Without it the AI-unavailable banner surfaces on dependent screens.
GOOGLE_GENERATIVE_AI_API_KEY=""

# --- Billing (optional) ----------------------------------------------------
# All Stripe routes 503 if the secret keys are missing. The webhook also
# 503s without STRIPE_WEBHOOK_SECRET (signature can't be verified).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- Public site URL (required in prod) ------------------------------------
# Used by middleware (request-id), sitemap, robots, OpenGraph metadata.
# Must be the canonical https URL in production.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Observability (optional) ----------------------------------------------
# Reserved for the swap-in inside src/lib/observability.ts. Today the seam
# is a no-op console wrapper; setting these has no effect until you wire
# the Sentry SDK. Documented here so the deploy checklist stays honest.
# SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"
